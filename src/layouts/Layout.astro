---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Engenharia que integra meio ambiente, automação e geoprocessamento." } = Astro.props;

const siteUrl = 'https://beleligeoengenharia.com.br';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = `${siteUrl}/og-image.png`;
const fullTitle = `${title} — Beleli GeoEngenharia`;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Beleli GeoEngenharia" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">

    <header class="bg-azul text-white relative z-50">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/">
          <img src="/logo.svg" alt="Beleli GeoEngenharia" class="h-30" />
        </a>

        <!-- Nav desktop (some on md+) -->
        <nav class="hidden md:flex gap-6 text-sm font-medium">
  <a href="/" class="hover:text-terracota transition-colors">Início</a>
  <a href="/servicos" class="hover:text-terracota transition-colors">Serviços</a>
  <a href="/galeria" class="hover:text-terracota transition-colors">Galeria</a>
  <a href="/sobre" class="hover:text-terracota transition-colors">Sobre</a>
  <a href="/contato" class="hover:text-terracota transition-colors">Contato</a>
</nav>

        <!-- Botão hambúrguer (só no mobile) -->
        <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menu">
          <span class="block w-6 h-0.5 bg-white transition-all" id="linha1"></span>
          <span class="block w-6 h-0.5 bg-white transition-all" id="linha2"></span>
          <span class="block w-6 h-0.5 bg-white transition-all" id="linha3"></span>
        </button>
      </div>

      <!-- Menu mobile (oculto por padrão) -->
      <div id="menu-mobile" class="hidden md:hidden bg-azul border-t border-white/10">
        <nav class="flex flex-col px-6 py-4 gap-4 text-sm font-medium">
  <a href="/" class="hover:text-terracota transition-colors">Início</a>
  <a href="/servicos" class="hover:text-terracota transition-colors">Serviços</a>
  <a href="/galeria" class="hover:text-terracota transition-colors">Galeria</a>
  <a href="/sobre" class="hover:text-terracota transition-colors">Sobre</a>
  <a href="/contato" class="hover:text-terracota transition-colors">Contato</a>
</nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-azul-dark text-white/70 text-sm">
      <div class="max-w-6xl mx-auto px-6 py-8 flex flex-col md:flex-row justify-between gap-4">
        <div>
          <p class="font-semibold text-white">Beleli GeoEngenharia</p>
          <p>Engenharia que integra meio ambiente, automação e geoprocessamento.</p>
        </div>
       <div class="text-right">
          <p>
            <a href="https://wa.me/5518997116392" target="_blank" rel="noopener" class="hover:text-white transition-colors">
              (18) 99711-6392
            </a>
          </p>
          <p>contato@beleligeoengenharia.com.br</p>
          <p>© {new Date().getFullYear()} Beleli GeoEngenharia</p>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu-mobile');
  const linha1 = document.getElementById('linha1');
  const linha2 = document.getElementById('linha2');
  const linha3 = document.getElementById('linha3');

  btn?.addEventListener('click', () => {
    const aberto = menu?.classList.toggle('hidden') === false;

    // Anima o ícone: vira um X quando aberto
    if (aberto) {
      linha1?.classList.add('rotate-45', 'translate-y-2');
      linha2?.classList.add('opacity-0');
      linha3?.classList.add('-rotate-45', '-translate-y-2');
    } else {
      linha1?.classList.remove('rotate-45', 'translate-y-2');
      linha2?.classList.remove('opacity-0');
      linha3?.classList.remove('-rotate-45', '-translate-y-2');
    }
  });

  // Fecha o menu ao clicar em qualquer link
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      linha1?.classList.remove('rotate-45', 'translate-y-2');
      linha2?.classList.remove('opacity-0');
      linha3?.classList.remove('-rotate-45', '-translate-y-2');
    });
  });
</script>
<script>
  // Animação on-scroll com IntersectionObserver
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target); // anima só uma vez
      }
    });
  }, {
    threshold: 0.1, // dispara quando 10% do elemento aparece
    rootMargin: '0px 0px -50px 0px' // pequena antecipação
  });

  document.querySelectorAll('.fade-in-up').forEach((el) => {
    observer.observe(el);
  });
</script>