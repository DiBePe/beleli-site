---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Conversor de Área" description="Conversão entre m², hectare, km² e os três alqueires brasileiros (paulista, mineiro/goiano e baiano).">

  <!-- HERO com breadcrumb -->
  <section class="bg-azul text-white py-16">
    <div class="max-w-6xl mx-auto px-6">
      <nav class="text-sm mb-4">
        <a href="/ferramentas" class="text-white/70 hover:text-terracota transition-colors">Ferramentas</a>
        <span class="text-white/50 mx-2">/</span>
        <span class="text-white/90">Conversor de Área</span>
      </nav>
      <p class="text-terracota font-medium mb-2 uppercase tracking-widest text-sm">Cálculo técnico</p>
      <h1 class="text-3xl md:text-4xl font-semibold">Conversor de Área</h1>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-cinza text-base mb-8 fade-in-up">Converte entre metro quadrado, hectare, quilômetro quadrado e os três principais alqueires brasileiros (paulista, mineiro/goiano e baiano).</p>

      <div class="bg-white rounded-lg p-6 md:p-8 shadow-sm fade-in-up border border-gray-100">
        <div class="mb-4">
          <label for="valor-origem" class="block text-sm font-medium text-azul mb-2">Valor</label>
          <div class="grid grid-cols-3 gap-3">
            <input type="number" id="valor-origem" inputmode="decimal" step="any" placeholder="0" class="col-span-2 border border-gray-200 rounded px-4 py-3 text-base focus:outline-none focus:border-azul transition-colors" />
            <select id="unidade-origem" class="border border-gray-200 rounded px-3 py-3 text-sm focus:outline-none focus:border-azul transition-colors bg-white">
              <option value="m2">m²</option>
              <option value="ha" selected>ha</option>
              <option value="km2">km²</option>
              <option value="alq_paulista">alq. paulista</option>
              <option value="alq_mineiro">alq. mineiro/goiano</option>
              <option value="alq_baiano">alq. baiano</option>
            </select>
          </div>
        </div>

        <div class="flex justify-center my-4">
          <button id="inverter" type="button" class="text-terracota hover:text-azul transition-colors p-2" aria-label="Inverter unidades">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 10l5 -5l5 5"/>
              <path d="M12 5v14"/>
              <path d="M7 14l5 5l5 -5"/>
            </svg>
          </button>
        </div>

        <div>
          <label for="valor-destino" class="block text-sm font-medium text-azul mb-2">Resultado</label>
          <div class="grid grid-cols-3 gap-3">
            <input type="text" id="valor-destino" readonly placeholder="0" class="col-span-2 border border-gray-200 rounded px-4 py-3 text-base bg-gray-50 text-azul font-medium" />
            <select id="unidade-destino" class="border border-gray-200 rounded px-3 py-3 text-sm focus:outline-none focus:border-azul transition-colors bg-white">
              <option value="m2" selected>m²</option>
              <option value="ha">ha</option>
              <option value="km2">km²</option>
              <option value="alq_paulista">alq. paulista</option>
              <option value="alq_mineiro">alq. mineiro/goiano</option>
              <option value="alq_baiano">alq. baiano</option>
            </select>
          </div>
        </div>
      </div>

      <div class="mt-12 fade-in-up">
        <h3 class="text-lg font-semibold text-azul mb-4">Fatores de conversão (em m²)</h3>
        <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100">
          <table class="w-full text-sm">
            <tbody class="divide-y divide-gray-100">
              <tr><td class="py-2 text-cinza">1 hectare (ha)</td><td class="py-2 text-azul text-right">10.000 m²</td></tr>
              <tr><td class="py-2 text-cinza">1 km²</td><td class="py-2 text-azul text-right">1.000.000 m²</td></tr>
              <tr><td class="py-2 text-cinza">1 alqueire paulista</td><td class="py-2 text-azul text-right">24.200 m² (2,42 ha)</td></tr>
              <tr><td class="py-2 text-cinza">1 alqueire mineiro / goiano</td><td class="py-2 text-azul text-right">48.400 m² (4,84 ha)</td></tr>
              <tr><td class="py-2 text-cinza">1 alqueire baiano</td><td class="py-2 text-azul text-right">96.800 m² (9,68 ha)</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-400 italic mt-3">
          Os alqueires brasileiros variam por região. Confirme com o cliente qual alqueire está em uso antes de relatórios oficiais.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-semibold text-azul mb-4">Precisa de cálculos técnicos específicos?</h2>
      <p class="text-cinza mb-8 max-w-xl mx-auto">Fale com a gente sobre seu projeto. Atendemos análise espacial, balanço hídrico, dimensionamento e estudos técnicos sob medida.</p>
      <a href="/contato" class="inline-block bg-terracota hover:bg-terracota/90 text-white font-medium px-6 py-3 rounded transition-colors">
        Solicitar avaliação técnica
      </a>
    </div>
  </section>

</Layout>

<script>
  const fatores: Record<string, number> = {
    'm2': 1, 'ha': 10000, 'km2': 1000000,
    'alq_paulista': 24200, 'alq_mineiro': 48400, 'alq_baiano': 96800,
  };

  const valorOrigem = document.getElementById('valor-origem') as HTMLInputElement;
  const valorDestino = document.getElementById('valor-destino') as HTMLInputElement;
  const unidadeOrigem = document.getElementById('unidade-origem') as HTMLSelectElement;
  const unidadeDestino = document.getElementById('unidade-destino') as HTMLSelectElement;
  const btnInverter = document.getElementById('inverter');

  function formatar(valor: number): string {
    if (!isFinite(valor)) return '';
    let casas = 4;
    const abs = Math.abs(valor);
    if (abs >= 1000) casas = 0;
    else if (abs >= 100) casas = 1;
    else if (abs >= 10) casas = 2;
    else if (abs >= 1) casas = 3;
    return valor.toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: casas });
  }

  function converter() {
    const valor = parseFloat(valorOrigem.value);
    if (isNaN(valor)) { valorDestino.value = ''; return; }
    const m2 = valor * fatores[unidadeOrigem.value];
    valorDestino.value = formatar(m2 / fatores[unidadeDestino.value]);
  }

  valorOrigem?.addEventListener('input', converter);
  unidadeOrigem?.addEventListener('change', converter);
  unidadeDestino?.addEventListener('change', converter);

  btnInverter?.addEventListener('click', () => {
    const tmp = unidadeOrigem.value;
    unidadeOrigem.value = unidadeDestino.value;
    unidadeDestino.value = tmp;
    converter();
  });
</script>